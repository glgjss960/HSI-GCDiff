{
  "name": "synthetic_proof",
  "seed": 7,
  "device": "cpu",
  "n_clusters": 4,
  "run": {
    "output_dir": "runs/synthetic_proof"
  },
  "data": {
    "synthetic": true,
    "height": 32,
    "width": 32,
    "classes": 4
  },
  "superpixel": {
    "n_segments": 140,
    "compactness": 8.0,
    "source_view": 0
  },
  "graph": {
    "neighbors": 8,
    "include_spatial_graph": true,
    "graph_views": [
      {
        "name": "spectral_stats",
        "source_view": 0,
        "mode": "mean_std",
        "neighbors": 8
      },
      {
        "name": "aux_stats",
        "source_view": 1,
        "mode": "mean_std",
        "neighbors": 8
      }
    ]
  },
  "encoder": {
    "hidden_dim": 64,
    "latent_dim": 32,
    "fusion": "mean",
    "epochs": 10,
    "lr": 0.002,
    "weight_decay": 0.0001,
    "consistency_weight": 0.05,
    "dropout": 0.1,
    "log_every": 5
  },
  "teacher": {
    "backend": "python_etap_lite",
    "n_anchors": 80,
    "k": 5,
    "strict_components": false
  },
  "target": {
    "source_key": "z_fuse",
    "assignment": "soft",
    "min_confidence": 0.0
  },
  "denoiser": {
    "source_key": "z_source",
    "cond_key": "z_fuse",
    "hidden_dim": 96,
    "time_dim": 32,
    "layers": 3,
    "timesteps": 20,
    "schedule": "linear",
    "epochs": 20,
    "lr": 0.002,
    "weight_decay": 0.0001,
    "dropout": 0.1,
    "min_weight": 0.05,
    "confidence_power": 1.0,
    "log_every": 10
  },
  "eval": {
    "timesteps": [0, 5, 10],
    "noise_seeds": [0, 1]
  }
}
