{
  "name": "mdas_proof_v2",
  "seed": 0,
  "device": "cuda",
  "run": {
    "output_dir": "runs/mdas_proof_v2"
  },
  "data": {
    "synthetic": false,
    "standardize": true,
    "views": [
      {
        "name": "hsi",
        "path": "../ETAP/data/MDAS/MDAS-Sub1-HSI.mat",
        "key": "Data_HSI",
        "pca_dim": 16
      },
      {
        "name": "dsm",
        "path": "../ETAP/data/MDAS/MDAS-Sub1-DSM.mat",
        "key": "Data_DSM",
        "pca_dim": 2
      }
    ],
    "gt_path": "../ETAP/data/MDAS/MDAS-Sub1-GT.mat",
    "gt_key": "GT"
  },
  "superpixel": {
    "n_segments": 235,
    "compactness": 10.0,
    "source_view": 0
  },
  "graph": {
    "neighbors": 10,
    "graph_views": [
      {
        "name": "hsi_stats",
        "role": "task",
        "source_view": 0,
        "mode": "mean_std",
        "neighbors": 10
      },
      {
        "name": "dsm_stats",
        "role": "aux",
        "source_view": 1,
        "mode": "mean_std",
        "neighbors": 10
      },
      {
        "name": "spatial",
        "role": "aux",
        "source_view": 0,
        "mode": "geometry",
        "graph": "spatial"
      }
    ]
  },
  "encoder": {
    "task_hidden_dim": 128,
    "aux_hidden_dim": 128,
    "latent_dim": 128,
    "epochs": 200,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "adj_recon_weight": 0.05,
    "aux_align_weight": 0.02,
    "dropout": 0.1,
    "log_every": 25
  },
  "target": {
    "mode": "task",
    "source_key": "z_task"
  },
  "denoiser": {
    "source_key": "z_aux",
    "target_key": "z_target",
    "condition": "none",
    "hidden_dim": 256,
    "time_dim": 64,
    "layers": 3,
    "timesteps": 100,
    "sampling_steps": 20,
    "noise_scale": 1.0,
    "epochs": 1000,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "dropout": 0.1,
    "min_weight": 0.05,
    "log_every": 100
  },
  "injection": {
    "alphas": [0, 0.05, 0.1, 0.2, 0.5, 1.0]
  },
  "eval": {
    "sampling_steps": [0, 10, 20],
    "noise_seeds": [0, 1, 2, 3, 4]
  }
}
