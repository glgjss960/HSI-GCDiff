{
  "name": "mdas_proof",
  "seed": 0,
  "device": "cuda",
  "run": {
    "output_dir": "runs/mdas_proof"
  },
  "data": {
    "synthetic": false,
    "standardize": true,
    "views": [
      {
        "name": "hsi",
        "path": "../ETAP/data/MDAS/MDAS-Sub1-HSI.mat",
        "key": "Data_HSI",
        "pca_dim": 16
      },
      {
        "name": "dsm",
        "path": "../ETAP/data/MDAS/MDAS-Sub1-DSM.mat",
        "key": "Data_DSM",
        "pca_dim": 2
      }
    ],
    "gt_path": "../ETAP/data/MDAS/MDAS-Sub1-GT.mat",
    "gt_key": "GT"
  },
  "superpixel": {
    "n_segments": 235,
    "compactness": 10.0,
    "source_view": 0
  },
  "graph": {
    "neighbors": 10,
    "include_spatial_graph": true,
    "graph_views": [
      {
        "name": "hsi_stats",
        "source_view": 0,
        "mode": "mean_std",
        "neighbors": 10
      },
      {
        "name": "dsm_stats",
        "source_view": 1,
        "mode": "mean_std",
        "neighbors": 10
      }
    ]
  },
  "encoder": {
    "hidden_dim": 128,
    "latent_dim": 128,
    "fusion": "mean",
    "epochs": 200,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "consistency_weight": 0.05,
    "dropout": 0.1,
    "log_every": 25
  },
  "teacher": {
    "backend": "python_etap_lite",
    "n_anchors": 235,
    "k": 5,
    "p_value": 0.1,
    "gamma": 0.00000001,
    "lambda": 0.00000001,
    "strict_components": false
  },
  "target": {
    "source_key": "z_fuse",
    "assignment": "soft",
    "min_confidence": 0.0
  },
  "denoiser": {
    "source_key": "z_source",
    "cond_key": "z_fuse",
    "hidden_dim": 256,
    "time_dim": 64,
    "layers": 3,
    "timesteps": 100,
    "schedule": "linear",
    "epochs": 1000,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "dropout": 0.1,
    "min_weight": 0.05,
    "confidence_power": 1.0,
    "log_every": 100
  },
  "eval": {
    "timesteps": [0, 10, 25, 50, 75],
    "noise_seeds": [0, 1, 2, 3, 4]
  }
}
